# syntax=docker/dockerfile:1.4
ARG PYTHON_VERSION=3.11-slim

FROM python:${PYTHON_VERSION}

WORKDIR /app

# Install system dependencies
# git/curl/bash for dev; gcc/libffi-dev/python3-dev for potential source builds of crypto
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
    bash \
    curl \
    git \
    gcc \
    libffi-dev \
    python3-dev \
    && rm -rf /var/lib/apt/lists/*

# Copy the project source
COPY . .

# Install with the [full] extra to include cryptography and all sub-packages
# Also install [build] if you want to be able to run build_pyz.py inside the container
RUN pip install --no-cache-dir -e ".[full,build]"

# Dworshak manages credentials/config; a volume ensures persistence across container restarts
VOLUME /root/.config/dworshak

ENTRYPOINT ["/bin/bash"]

LABEL org.opencontainers.image.source=https://github.com/city-of-memphis-wastewater/dworshak
LABEL org.opencontainers.image.description="Developer environment for dworshak - includes waterfall configuration and credential management with cryptography support."
